{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "_description": "constants.env の定数と settings.yaml 由来の REPO_SLUG / WIKI_BASE を CLAUDE_ENV_FILE 経由でセッション内に展開",
            "type": "command",
            "command": "bash",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/session-start/load-constants.sh"
            ]
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "_description": "マージ前に master 取り込み確認＋dry-run コンフリクトチェック",
            "type": "command",
            "command": "python",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use/pre-merge-check.py"
            ]
          }
        ]
      },
      {
        "matcher": "Edit|Write|Read",
        "hooks": [
          {
            "_description": "編集対象ファイルにマッチする開発ルールを注入",
            "type": "command",
            "command": "python",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use/inject-rules/injector.py"
            ]
          }
        ]
      }
    ]
  }
}
