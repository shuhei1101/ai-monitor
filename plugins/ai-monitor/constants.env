# ai-monitor 静的定数（SoT）
#
# 書式: KEY="value" のみ（コメント行・空行可）。コマンド実行や変数展開は書かない
# 読み込み方法:
#   bash:   set -a; source constants.env; set +a
#   セッション: SessionStart フック（hooks/session-start/load-constants.sh）が CLAUDE_ENV_FILE 経由で展開
#   python: KEY="value" を行パースする（コメント・空行スキップ）
# セッション固有の値（REPO_SLUG / WIKI_BASE）は load-constants.sh が settings.yaml から解決して展開する

# 共通
AI_MONITOR_LABEL_IN_DISCUSSION="議論中"
AI_MONITOR_LABEL_PROCESSING_PREFIX="処理中:"

# ai-monitor 自身の Wiki raw URL のベース（共通対応表・共通ルールの取得元。プロジェクト側は WIKI_BASE）
AI_MONITOR_WIKI_BASE="https://raw.githubusercontent.com/shuhei1101/ai-monitor/master/docs/wiki"

# レイヤー（intake-issue-triager が判定して付与）
AI_MONITOR_LABEL_LAYER_INTAKE="layer:intake"
AI_MONITOR_LABEL_LAYER_EPIC="layer:epic"
AI_MONITOR_LABEL_LAYER_STORY="layer:story"
AI_MONITOR_LABEL_LAYER_SUBSYSTEM="layer:subsystem"
AI_MONITOR_LABEL_LAYER_CHORE="layer:chore"

# --- 起点 ---
# 1. intake-issue-triager
AI_MONITOR_LABEL_CONFIRM_INTAKE_ISSUE_TRIAGER="確認:intake-issue-triager"
AI_MONITOR_LABEL_PROCESSING_INTAKE_ISSUE_TRIAGER="処理中:intake-issue-triager"

# --- epic レイヤー ---
# 2. epic-conductor
AI_MONITOR_LABEL_CONFIRM_EPIC_CONDUCTOR="確認:epic-conductor"
AI_MONITOR_LABEL_PROCESSING_EPIC_CONDUCTOR="処理中:epic-conductor"

# 21. epic-poc-runner（epic-conductor の後・条件付き）
AI_MONITOR_LABEL_CONFIRM_EPIC_POC_RUNNER="確認:epic-poc-runner"
AI_MONITOR_LABEL_PROCESSING_EPIC_POC_RUNNER="処理中:epic-poc-runner"

# 22. mock-designer（epic PR 作成後・画面変更ありの場合のみ）
AI_MONITOR_LABEL_CONFIRM_MOCK_DESIGNER="確認:mock-designer"
AI_MONITOR_LABEL_PROCESSING_MOCK_DESIGNER="処理中:mock-designer"

# 4. complex-scenario-writer
AI_MONITOR_LABEL_CONFIRM_COMPLEX_SCENARIO_WRITER="確認:complex-scenario-writer"
AI_MONITOR_LABEL_PROCESSING_COMPLEX_SCENARIO_WRITER="処理中:complex-scenario-writer"

# 5. complex-scenario-tester
AI_MONITOR_LABEL_CONFIRM_COMPLEX_SCENARIO_TESTER="確認:complex-scenario-tester"
AI_MONITOR_LABEL_PROCESSING_COMPLEX_SCENARIO_TESTER="処理中:complex-scenario-tester"

# --- story レイヤー ---
# 6. story-conductor
AI_MONITOR_LABEL_CONFIRM_STORY_CONDUCTOR="確認:story-conductor"
AI_MONITOR_LABEL_PROCESSING_STORY_CONDUCTOR="処理中:story-conductor"

# 8. single-scenario-writer
AI_MONITOR_LABEL_CONFIRM_SINGLE_SCENARIO_WRITER="確認:single-scenario-writer"
AI_MONITOR_LABEL_PROCESSING_SINGLE_SCENARIO_WRITER="処理中:single-scenario-writer"

# 9. single-scenario-tester
AI_MONITOR_LABEL_CONFIRM_SINGLE_SCENARIO_TESTER="確認:single-scenario-tester"
AI_MONITOR_LABEL_PROCESSING_SINGLE_SCENARIO_TESTER="処理中:single-scenario-tester"

# --- subsystem レイヤー ---
# 10. subsystem-conductor
AI_MONITOR_LABEL_CONFIRM_SUBSYSTEM_CONDUCTOR="確認:subsystem-conductor"
AI_MONITOR_LABEL_PROCESSING_SUBSYSTEM_CONDUCTOR="処理中:subsystem-conductor"

# 13. architect
AI_MONITOR_LABEL_CONFIRM_ARCHITECT="確認:architect"
AI_MONITOR_LABEL_PROCESSING_ARCHITECT="処理中:architect"

# 23. library-poc-runner（architect の PoC 発注・条件付き）
AI_MONITOR_LABEL_CONFIRM_LIBRARY_POC_RUNNER="確認:library-poc-runner"
AI_MONITOR_LABEL_PROCESSING_LIBRARY_POC_RUNNER="処理中:library-poc-runner"

# 14. tester
AI_MONITOR_LABEL_CONFIRM_TESTER="確認:tester"
AI_MONITOR_LABEL_PROCESSING_TESTER="処理中:tester"

# 15. implementer
AI_MONITOR_LABEL_CONFIRM_IMPLEMENTER="確認:implementer"
AI_MONITOR_LABEL_PROCESSING_IMPLEMENTER="処理中:implementer"

# --- 独立系 ---
# 18. resetter
AI_MONITOR_LABEL_CONFIRM_RESETTER="確認:resetter"
AI_MONITOR_LABEL_PROCESSING_RESETTER="処理中:resetter"

# 19. quick-implementer
AI_MONITOR_LABEL_CONFIRM_QUICK_IMPLEMENTER="確認:quick-implementer"
AI_MONITOR_LABEL_PROCESSING_QUICK_IMPLEMENTER="処理中:quick-implementer"

# 20. questioner
AI_MONITOR_LABEL_CONFIRM_QUESTIONER="確認:questioner"
AI_MONITOR_LABEL_PROCESSING_QUESTIONER="処理中:questioner"

# ---------------------------------------------------------------------
# その他のラベル
# ---------------------------------------------------------------------

# 優先度（ユーザーが付与）
AI_MONITOR_LABEL_PRIORITY_URGENT="優先度:急ぎ"
AI_MONITOR_LABEL_PRIORITY_LOW="優先度:いつでも"

# タイプ（issue-triager が付与）
AI_MONITOR_LABEL_TYPE_BUG="type:bug"
AI_MONITOR_LABEL_TYPE_FEAT="type:feat"
AI_MONITOR_LABEL_TYPE_REFACTOR="type:refactor"
AI_MONITOR_LABEL_TYPE_DOCS="type:docs"
AI_MONITOR_LABEL_TYPE_CHORE="type:chore"
AI_MONITOR_LABEL_TYPE_TEST="type:test"

