# ai-monitor 設定サンプル
# 実運用は .env にコピーして書き換える（.env は .gitignore 済み）

# ---- 監視対象プロジェクト（複数宣言可）--------------------
# パターン: AI_MONITOR_PROJECT_{PROJECT_NAME}_{FIELD}
# FIELD: REPO / LOCAL_PATH / WIKI_BASE

AI_MONITOR_PROJECT_MYAPP_REPO=owner/myapp
AI_MONITOR_PROJECT_MYAPP_LOCAL_PATH=/mnt/c/Users/shuhe/repo/myapp
AI_MONITOR_PROJECT_MYAPP_WIKI_BASE=/mnt/c/Users/shuhe/repo/myapp/docs/wiki

# 2 つ目以降は同じパターンで追加
# AI_MONITOR_PROJECT_SIDEKICK_REPO=owner/sidekick
# AI_MONITOR_PROJECT_SIDEKICK_LOCAL_PATH=/mnt/c/Users/shuhe/repo/sidekick
# AI_MONITOR_PROJECT_SIDEKICK_WIKI_BASE=/mnt/c/Users/shuhe/repo/sidekick/docs/wiki

# ---- orchestrator 自身の設定 ------------------------------
AI_MONITOR_FASTAPI_HOST=127.0.0.1
AI_MONITOR_FASTAPI_PORT=8765

# ポーリング間隔（秒）
AI_MONITOR_POLL_INTERVAL_SEC=15

# tmux セッションのアイドルタイムアウト（分）。超過で kill
AI_MONITOR_SESSION_TIMEOUT_MIN=30

# heartbeat のチェック間隔（秒）
AI_MONITOR_HEARTBEAT_INTERVAL_SEC=60

# SQLite state store のパス
AI_MONITOR_STATE_DB_PATH=data/state.sqlite
